package paquete;

import java.util.Scanner;

public class Calculadora {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		String argumento = sc.nextLine();
		int acum = 0;
		
		do {
			acum += Integer.parseInt(argumento);
		} while (!argumento.equals("*"));
		//System.exit(acum);
	}

}
