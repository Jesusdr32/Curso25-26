package multiprocesoIII;

import java.io.BufferedReader;
import java.io.BufferedWriter;
import java.io.File;
import java.io.IOException;
import java.io.InputStreamReader;
import java.io.OutputStreamWriter;
import java.util.Scanner;

public class LlamarCalculadora_Fichero {

	public static void main(String[] args) throws IOException, InterruptedException{
		
		File directorio = new File("C:\\Users\\Vespertino\\Desktop\\DA2D1E\\PSP+PMDM\\Unidad2\\ProcessBuilder\\Hijos\\bin");
		
		ProcessBuilder pb = new ProcessBuilder("java", "paquete.Calculadora");
		
		pb.directory(directorio);
		
		File fIn = new File("C:\\Users\\Vespertino\\Desktop\\DA2D1E\\PSP+PMDM\\Unidad2\\ProcessBuilder", "datos.txt");
		
		File fOut = new File("C:\\Users\\Vespertino\\Desktop\\DA2D1E\\PSP+PMDM\\Unidad2\\ProcessBuilder", "suma.txt");
		
		File fErr = new File("C:\\Users\\Vespertino\\Desktop\\DA2D1E\\PSP+PMDM\\Unidad2\\ProcessBuilder", "error.txt");
		
		pb.redirectInput(fIn);
		
		pb.redirectOutput(fOut);
		
		pb.redirectError(fErr);
		
		Process p = pb.start();
		
		BufferedReader br = new BufferedReader(new InputStreamReader(p.getInputStream()));
		
		String linea;
		
		boolean finalizar = false;
		
		while (!finalizar && (linea = br.readLine()) != null) {
			try {
				int numero = Integer.parseInt(linea.trim());
				System.out.println("Número recibido: " + numero);
			} catch (NumberFormatException e) {
				System.err.println("Error: línea no numérica -> '" + linea + "'");
			}
			if (linea.contains("*"))
				finalizar = true;
		}
		
		
		int valorSalida = 99;
		
		try {
			valorSalida = p.waitFor();
			
			if (valorSalida == 0) {
				System.out.println("Valor de salida: " + valorSalida);
				
				System.out.println(br.readLine());
			}
		} catch (InterruptedException e) {
			e.printStackTrace();
		}
		
		bw.close();
		br.close();
		sc.close();
	}

}
